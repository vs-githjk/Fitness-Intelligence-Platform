POSTGRES_DB=fitness
POSTGRES_USER=fitness
POSTGRES_PASSWORD=fitness_dev_password
APP_ENV=local
DATABASE_URL=postgresql+psycopg://fitness:fitness_dev_password@db:5432/fitness
MIGRATION_DATABASE_URL=postgresql+psycopg://fitness:fitness_dev_password@db:5432/fitness
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
ACCESS_TOKEN_MINUTES=480
CORS_ORIGINS=http://localhost:5175
TRUSTED_HOSTS=localhost,127.0.0.1,backend
DEMO_INVITE_CODE=FIT-DEMO-2026
COACH_REGISTRATION_CODE=replace-with-a-private-coach-registration-code
DEMO_MODE_ENABLED=true
DEMO_SESSION_MINUTES=30
SEED_DEMO_DATA=false
# Media storage. Only 'local' is implemented; production rejects local media because
# its filesystem is ephemeral. Bytes are served through the authorized media endpoint,
# never as a public static route. MEDIA_LOCAL_ROOT is gitignored (backend/media/).
MEDIA_STORAGE_PROVIDER=local
MEDIA_LOCAL_ROOT=./media
MEDIA_MAX_BYTES=5242880
LOG_LEVEL=INFO
API_DOCS_ENABLED=true
PORT=8000
DATABASE_SSLMODE=disable
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_CONNECT_TIMEOUT=5
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_ENV=local
