APP_ENV=local
DATABASE_URL=postgresql+psycopg://fitness:fitness_dev_password@db:5432/fitness
MIGRATION_DATABASE_URL=postgresql+psycopg://fitness:fitness_dev_password@db:5432/fitness
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
